{
  "schemaVersion": 3,
  "forbiddenTrackedPatterns": [
    ".routelab-private/**",
    ".serena/**",
    "AGENTS.override.md",
    ".codex/initial-prompt.md",
    ".codex/second-prompt.md",
    ".codex/prompts/**",
    "**/raw/**",
    "**/prompts/**",
    "**/transcripts/**",
    "**/session-notes/**",
    "**/agent-reports/**",
    "**/ACTIVE_STATUS.md",
    "**/*prompt*.md",
    "**/*transcript*.md",
    "**/*session-notes*.md",
    "reviews/raw/**",
    "docs/research-papers/**",
    "private/**",
    "secrets/**",
    ".env",
    ".env.*",
    "SETUP.md",
    "MANIFEST.md",
    "routelab-codex-4-agent-setup/**",
    "**/*.zip",
    "**/*.tar*",
    "**/*.7z"
  ],
  "allowedForbiddenPathExceptions": [
    ".env.example"
  ],
  "allowedTopLevelFiles": [
    ".env.example",
    ".gitignore",
    ".nvmrc",
    "AGENTS.md",
    "IMPLEMENTATION_PLAN.md",
    "README.md",
    "STATUS.md",
    "eslint.config.mjs",
    "package.json",
    "pnpm-lock.yaml",
    "tsconfig.json"
  ],
  "allowedTrackedRoots": [
    ".github/",
    "cli/",
    "config/",
    "fixtures/",
    "scripts/",
    "src/",
    "tests/"
  ],
  "allowedTrackedPaths": [
    ".agent/PLANS.md",
    ".codex/config.toml",
    ".codex/agents/builder.toml",
    ".codex/agents/oracle.toml",
    ".codex/agents/reviewer.toml",
    "tasks/TASK_TEMPLATE.md",
    "tasks/examples/**",
    "docs/CODEX_OPERATING_MODEL.md",
    "docs/CODE_REVIEW.md",
    "docs/invariants.md",
    "docs/references.md",
    "docs/engineering-log/**",
    "docs/adr/accepted/**",
    "docs/experiments/published/**"
  ],
  "allowedPublicAgentPaths": [
    ".codex/config.toml",
    ".codex/agents/builder.toml",
    ".codex/agents/oracle.toml",
    ".codex/agents/reviewer.toml"
  ],
  "requiredTrackedPaths": [
    "AGENTS.md",
    "IMPLEMENTATION_PLAN.md",
    "STATUS.md",
    ".codex/config.toml",
    ".codex/agents/builder.toml",
    ".codex/agents/oracle.toml",
    ".codex/agents/reviewer.toml",
    "docs/CODEX_OPERATING_MODEL.md"
  ],
  "secretMarkerPatterns": [
    "-----BEGIN (?:RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----",
    "AKIA[0-9A-Z]{16}",
    "github_pat_[A-Za-z0-9_]{20,}",
    "ghp_[A-Za-z0-9]{20,}",
    "glpat-[A-Za-z0-9_-]{20,}",
    "xox[baprs]-[A-Za-z0-9-]{10,}",
    "npm_[A-Za-z0-9]{20,}",
    "sk_live_[A-Za-z0-9]{20,}",
    "sk-[A-Za-z0-9]{20,}"
  ],
  "secretScanExclusions": [
    "config/public-surface.json",
    "tests/trace-policy.test.ts"
  ],
  "engineeringLogDirectory": "docs/engineering-log",
  "engineeringLogIndex": "docs/engineering-log/README.md",
  "engineeringLogRequiredFields": [
    "Date:",
    "Status: integrated",
    "Relevant commit(s):",
    "## Problem / why this was next",
    "## Decision or implementation",
    "## Evidence and commands",
    "## Result",
    "## Limitations / what remains unimplemented",
    "## Links to accepted public artifacts"
  ],
  "processSizeBudgets": [
    {"name":"root project contract","paths":["AGENTS.md"],"maxBytes":12288},
    {"name":"public custom roles combined","paths":[".codex/agents/builder.toml",".codex/agents/oracle.toml",".codex/agents/reviewer.toml"],"maxBytes":7168},
    {"name":"public operating model","paths":["docs/CODEX_OPERATING_MODEL.md"],"maxBytes":7168},
    {"name":"public product roadmap","paths":["IMPLEMENTATION_PLAN.md"],"maxBytes":20480}
  ],
  "processSizeAllowlist": []
}
