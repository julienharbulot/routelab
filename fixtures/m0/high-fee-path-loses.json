      "reserve1": "1000",
      "feeChargedNumerator": "0",
      "feeDenominator": "1"
    },
    {
      "poolId": "high-fee-ab",
      "asset0": "A",
      "reserve0": "1000",
      "asset1": "B",
      "reserve1": "1000",
      "feeChargedNumerator": "90",
      "feeDenominator": "100"
    }
  ],
  "expected": {
    "outcome": "route-comparison",
    "zeroFeePath": {
