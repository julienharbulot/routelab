{
  "name": "routelab-ts",
  "version": "0.1.0",
  "description": "Exact-input routing over immutable constant-product liquidity snapshots",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/julienharbulot/routelab.git"
  },
  "homepage": "https://github.com/julienharbulot/routelab#readme",
  "bugs": {
    "url": "https://github.com/julienharbulot/routelab/issues"
  },
  "keywords": [
    "typescript",
    "defi",
    "liquidity-routing",
    "bigint",
    "benchmarking",
    "near-intents"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./near-intents-fixture": {
      "types": "./dist/adapters/near-intents/index.d.ts",
      "import": "./dist/adapters/near-intents/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "DATA_NOTICE.md",
    "LICENSE"
  ],
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=24.12.0 <25",
    "pnpm": "11.12.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "node scripts/clean-dist.ts && tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "lint": "eslint src cli scripts tests",
    "test": "node --test \"tests/**/*.test.ts\"",
    "test:pool": "node --test tests/constant-product.test.ts",
    "verify:inputs": "node cli/verify-inputs.ts",
    "demo": "node cli/demo.ts",
    "quote": "node cli/quote.ts",
    "benchmark": "node cli/benchmark.ts",
    "benchmark:verify": "node cli/verify-benchmark.ts",
    "benchmark:smoke": "node cli/benchmark.ts --smoke",
    "test:benchmark": "node --test tests/portfolio-benchmark.test.ts",
    "serve": "node cli/serve.ts",
    "serve:smoke": "node cli/serve.ts --smoke",
    "test:api": "node --test tests/http-service.test.ts tests/http-load.test.ts",
    "load": "node cli/load.ts",
    "load:deadlines": "node cli/load-deadlines.ts",
    "load:overload": "node cli/load-overload.ts",
    "load:smoke": "node cli/load.ts --smoke",
    "service:verify": "node cli/verify-service-report.ts",
    "test:intents": "node --test tests/near-intents-adapter.test.ts",
    "test:package": "node scripts/test-package.ts",
    "test:core": "node --test tests/constant-product.test.ts tests/route-replay.test.ts tests/exact-input-split-replay.test.ts tests/simple-paths.test.ts tests/pool-disjoint-route-sets.test.ts tests/path-shadow-price-allocation.test.ts tests/anytime-exact-input-split-router.test.ts tests/numerical-exact-input-split-router.test.ts tests/public-facade.test.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm verify:inputs && pnpm demo",
    "release:verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:package && pnpm verify:inputs && pnpm benchmark:verify && pnpm service:verify && pnpm test:api && pnpm serve:smoke && pnpm load:smoke && pnpm pack --dry-run"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.63.0"
  }
}
