{
  "name": "routelab-ts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=24.12.0 <25",
    "pnpm": "11.12.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src cli tests",
    "test": "node --test \"tests/**/*.test.ts\"",
    "test:pool": "node --test tests/constant-product.test.ts",
    "replay:cases": "node cli/replay-cases.ts",
    "replay:split-cases": "node cli/replay-split-cases.ts",
    "verify:historical-data": "node cli/verify-historical-dataset.ts",
    "verify:synthetic-requests": "node cli/verify-synthetic-request-corpus.ts",
    "measure:anytime": "node cli/measure-anytime.ts",
    "demo": "node cli/demo.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm verify:historical-data && pnpm verify:synthetic-requests && pnpm demo"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.63.0"
  }
}
